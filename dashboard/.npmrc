# npm 12+ desabilita dependências git por padrão (allow-git=none, hardening contra
# supply-chain attacks). Precisamos disso só para @wri-brasil/design-system, um
# repositório PRIVADO da própria autora (não é dependência de terceiro desconhecido) —
# ver CLAUDE.md, seção "Pegadinhas", para o contexto completo.
allow-git=root
